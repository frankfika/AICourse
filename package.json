{
  "name": "ai-academy",
  "version": "1.0.0",
  "private": true,
  "description": "AI Academy - AI and LLM education platform",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @ai-academy/web dev",
    "dev:api": "pnpm --filter @ai-academy/api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @ai-academy/web build",
    "build:api": "pnpm --filter @ai-academy/api build",
    "start": "pnpm --filter @ai-academy/api start",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @ai-academy/api db:migrate",
    "db:studio": "pnpm --filter @ai-academy/api db:studio",
    "db:seed": "pnpm --filter @ai-academy/api db:seed"
  },
  "devDependencies": {
    "@prisma/client": "6.2.0",
    "@types/node": "^22.14.0",
    "prisma": "6.2.0",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "onlyBuiltDependencies": [
    "prisma",
    "@prisma/client",
    "@prisma/engines",
    "bcrypt",
    "esbuild",
    "protobufjs"
  ],
  "dependencies": {
    "zod": "^3.25.76"
  }
}
