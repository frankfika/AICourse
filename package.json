{
  "name": "opencsg-academy",
  "version": "1.0.0",
  "private": true,
  "description": "OpenCSG Academy - AI and LLM education platform",
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "dev:web": "pnpm --filter @opencsg/academy-web dev",
    "dev:api": "pnpm --filter @opencsg/academy-api dev",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @opencsg/academy-web build",
    "build:api": "pnpm --filter @opencsg/academy-api build",
    "start": "pnpm --filter @opencsg/academy-api start",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "db:migrate": "pnpm --filter @opencsg/academy-api db:migrate",
    "db:studio": "pnpm --filter @opencsg/academy-api db:studio",
    "db:seed": "pnpm --filter @opencsg/academy-api db:seed"
  },
  "devDependencies": {
    "@prisma/client": "6.2.0",
    "@types/node": "^22.14.0",
    "prisma": "6.2.0",
    "typescript": "~5.8.2"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "bcrypt",
      "prisma",
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "protobufjs"
    ],
    "overrides": {
      "tar": ">=7.5.11",
      "js-yaml": ">=4.2.0",
      "multer": ">=2.2.0",
      "vite": ">=6.4.3",
      "vitest": ">=3.2.6"
    }
  },
  "dependencies": {
    "zod": "^3.25.76"
  }
}
