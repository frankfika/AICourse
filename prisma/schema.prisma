generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==================== 用户与权限 ====================
model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String    @map("password_hash")
  name            String
  role            UserRole  @default(student)
  avatarUrl       String?   @map("avatar_url")
  passwordResetRequired Boolean @default(false) @map("password_reset_required")
  points          Int       @default(0)
  level           Int       @default(1)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  lastLoginAt     DateTime? @map("last_login_at")

  refreshTokens   RefreshToken[]
  providerAccounts UserProviderAccount[]
  enrollments     Enrollment[]
  orders          Order[]
  progressRecords ProgressRecord[]
  auditLogs       AuditLog[]
  teamMembers     TeamMember[]
  hackathonRegs   HackathonRegistration[]
  submissions     Submission[]
  practiceCompletions PracticeCompletion[]
  userBadges      UserBadge[]
  pointTransactions PointTransaction[]
  organizedHackathons Hackathon[] @relation("OrganizedHackathons")
  reviews         Review[]
  notifications Notification[]
  // P1-8: 证书（学位 / 课程 / 黑客松完成时签发）
  certificates   Certificate[]
  // P2: 新增关联 (chat / learning events / AI usage)
  chatSessions    ChatSession[]
  learningEvents  LearningEvent[]
  aiUsage         AiUsage[]

  @@map("users")
}

// ==================== 证书（P1-8）====================
// 三类签发:course(单课程) / degree(学位) / hackathon(黑客松获奖)
// serial 格式: OCSG-{YEAR}-{TYPE}-{4位序号}, 全表 unique
// revokedAt 非空表示已撤销(管理员操作), 公开 verify 接口会查
// metadata 装 JSON(评分 / 排名 / 备注等扩展信息)
model Certificate {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  // 'course' | 'degree' | 'hackathon'
  type         String
  // 关联的 course / degree / hackathon id
  refId        String   @map("ref_id")
  title        String
  description  String?  @db.Text
  // 证书编号 (e.g. "OCSG-2026-COURSE-0001")
  serialNumber String   @unique @map("serial_number")
  issuedAt     DateTime @default(now()) @map("issued_at")
  // 课程 / 学位 / 黑客松完成时间
  completedAt  DateTime @map("completed_at")
  // 证书图片 URL (mock: 静态占位)
  imageUrl     String?  @map("image_url")
  // 公开可验证 URL
  verifyUrl    String?  @map("verify_url")
  // 元数据: 评分 / 排名 / 备注
  metadata     Json?
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
  @@index([refId, type])
  @@index([serialNumber])
  @@map("certificates")
}

enum UserRole {
  admin
  student
  instructor
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ==================== Auth 抽象层 - 多 Provider 绑定 ====================
// 一个 user 可绑定多个 provider 账号（email/password + google + 企业 SSO ...）
// 设计目标：可插拔 + 配置驱动 + 不重复造轮子
//
// P2 扩展：显式字段（email / displayName / isPrimary / linkedAt / lastUsedAt / deletedAt）
// 原本只在 profile JSON 里有,前端 BindingsPage / admin / 风控都需要显式列
// → 加列, 旧数据由 migration 回填 (从 profile JSON 解析 + createdAt → linkedAt, updatedAt → lastUsedAt)
model UserProviderAccount {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  // provider 标识,如 "email_password" / "oauth.google" / "sso.saml"
  // 用 String 而非 enum,新增 provider 不需要改 schema + 不需要 migration
  provider        String
  // 该 provider 内部的 user id（email / oauth sub / saml NameID）
  providerUserId  String   @map("provider_user_id")

  // ---- P2 新增显式字段 ----
  // 第三方 profile 拉到的 email（即使本表 user.email 不一致,也保留第三方侧的）
  email           String?
  // 第三方 profile 拉到的显示名
  displayName     String?  @map("display_name")
  // 是否为该 user 的主登录方式（解绑时不允许删主身份）
  isPrimary       Boolean  @default(false) @map("is_primary")
  // 绑定时间（原 createdAt 的语义迁移,数据回填用）
  linkedAt        DateTime @default(now()) @map("linked_at")
  // 最后使用时间（原 updatedAt 的语义迁移）
  lastUsedAt      DateTime @default(now()) @map("last_used_at")
  // 软删时间（P2：解绑走软删,保留审计可追溯）
  deletedAt       DateTime? @map("deleted_at")

  // 原始 profile / claims JSON,留作 audit + 后续扩展
  profile         Json?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@index([userId, deletedAt])
  @@map("user_provider_accounts")
}

// ==================== 课程结构 ====================
model Course {
  id             String       @id @default(uuid())
  title          String
  description    String       @db.Text
  learningPoints String       @map("learning_points") @db.Text
  instructor     String
  instructorId   String?      @map("instructor_id")
  level          CourseLevel
  duration       String
  thumbnail      String
  tags           String       @db.Text
  costType        CostType     @map("cost_type")
  price           Decimal      @default(0) @db.Decimal(10, 2)
  status          CourseStatus @default(draft)
  courseType      CourseType   @default(own) @map("course_type")
  externalUrl     String?      @map("external_url")
  sourceVideoUrl  String?      @unique @map("source_video_url")
  sourcePlatform  String?      @map("source_platform")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  chapters         Chapter[]
  enrollments      Enrollment[]
  orders           Order[]
  progressRecords  ProgressRecord[]
  degreeCourses    DegreeCourse[]
  practiceProjects PracticeProject[]
  reviews          Review[]

  @@map("courses")
}

enum CourseLevel {
  Beginner
  Intermediate
  Advanced
  Expert
}

enum CostType {
  free
  paid
  charity
}

enum CourseStatus {
  draft
  published
  archived
}

enum CourseType {
  own          // 自有课程
  partner      // 合作课程
  public       // 公开课程
  third_party  // 第三方课程
}

model Chapter {
  id          String   @id @default(uuid())
  courseId    String   @map("course_id")
  title       String
  description String?  @db.Text
  orderIndex  Int      @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  // P2: 软删 — admin 端点删章节走软删,前端 / 用户进度仍能查到
  deletedAt   DateTime? @map("deleted_at")

  course  Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons Lesson[]

  @@index([courseId, deletedAt])
  @@map("chapters")
}

model Lesson {
  id            String   @id @default(uuid())
  chapterId     String   @map("chapter_id")
  title         String
  description   String?  @db.Text
  videoUrl      String?  @map("video_url")
  videoDuration Int?     @map("video_duration")
  orderIndex    Int      @map("order_index")
  isPreview     Boolean  @default(false) @map("is_preview")
  createdAt     DateTime @default(now()) @map("created_at")
  // P2: 软删
  deletedAt     DateTime? @map("deleted_at")

  chapter   Chapter          @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  resources Resource[]
  progress  ProgressRecord[]
  // P2 关联
  learningEvents LearningEvent[]
  chatSessions   ChatSession[]

  @@index([chapterId, deletedAt])
  @@map("lessons")
}

model Resource {
  id        String       @id @default(uuid())
  lessonId  String       @map("lesson_id")
  title     String
  url       String
  type      ResourceType
  isLocked  Boolean      @default(true) @map("is_locked")
  createdAt DateTime     @default(now()) @map("created_at")
  // P2: 软删
  deletedAt DateTime? @map("deleted_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, deletedAt])
  @@map("resources")
}

enum ResourceType {
  pdf
  code
  link
  video
  audio
}

// ==================== 学位 ====================
model NanoDegree {
  id             String       @id @default(uuid())
  title          String
  description    String       @db.Text
  learningPoints String       @map("learning_points") @db.Text
  price          Decimal      @db.Decimal(10, 2)
  icon           String       @default("sparkles")
  costType       CostType     @map("cost_type")
  thumbnail      String?
  status         CourseStatus @default(draft)
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  courses     DegreeCourse[]
  enrollments Enrollment[]
  orders      Order[]

  @@map("nano_degrees")
}

model DegreeCourse {
  degreeId   String @map("degree_id")
  courseId   String @map("course_id")
  orderIndex Int    @default(0) @map("order_index")

  degree NanoDegree @relation(fields: [degreeId], references: [id], onDelete: Cascade)
  course Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@id([degreeId, courseId])
  @@map("degree_courses")
}

// ==================== 注册与权限 ====================
model Enrollment {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  courseId   String?  @map("course_id")
  degreeId   String?  @map("degree_id")
  enrolledAt DateTime @default(now()) @map("enrolled_at")
  expiresAt  DateTime? @map("expires_at")
  source     EnrollmentSource @default(direct)

  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course?     @relation(fields: [courseId], references: [id], onDelete: SetNull)
  degree NanoDegree? @relation(fields: [degreeId], references: [id], onDelete: SetNull)

  @@unique([userId, courseId])
  @@unique([userId, degreeId])
  @@map("enrollments")
}

enum EnrollmentSource {
  direct
  degree
  hackathon
  promotion
  order
}

// ==================== 订单与支付 ====================
model Order {
  id            String      @id @default(uuid())
  userId        String      @map("user_id")
  type          OrderType
  courseId      String?     @map("course_id")
  degreeId      String?     @map("degree_id")
  amount        Decimal     @db.Decimal(10, 2)
  currency      String      @default("CNY")
  status        OrderStatus @default(pending)
  paymentMethod String?     @map("payment_method")
  transactionId String?     @map("transaction_id")
  paidAt        DateTime?   @map("paid_at")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course?    @relation(fields: [courseId], references: [id], onDelete: SetNull)
  degree NanoDegree? @relation(fields: [degreeId], references: [id], onDelete: SetNull)

  @@map("orders")
}

enum OrderType {
  course
  degree
}

enum OrderStatus {
  pending
  paid
  failed
  expired
  refunded
}

// ==================== 黑客松 ====================
model Hackathon {
  id               String          @id @default(uuid())
  title            String
  description      String          @db.Text
  bannerUrl        String?         @map("banner_url")
  status           HackathonStatus @default(upcoming)
  startDate        DateTime        @map("start_date")
  endDate          DateTime        @map("end_date")
  registerDeadline DateTime?       @map("register_deadline")
  maxTeamSize      Int             @default(5) @map("max_team_size")
  minTeamSize      Int             @default(1) @map("min_team_size")
  location         String?
  rules            String?         @db.Text
  prizes           String?         @db.Text
  // 外部 CTA 链接(基础信息在 tab 里, 详情页只挂 1 个外链: 报名 / 了解更多)
  registrationUrl  String?         @map("registration_url")
  registrationLabel String?        @map("registration_label")
  organizerId      String?         @map("organizer_id")
  createdAt        DateTime        @default(now()) @map("created_at")
  updatedAt        DateTime        @updatedAt @map("updated_at")

  registrations HackathonRegistration[]
  teams         Team[]
  judges        Judge[]
  submissions   Submission[]
  announcements Announcement[]
  organizer     User?           @relation("OrganizedHackathons", fields: [organizerId], references: [id], onDelete: SetNull)

  @@map("hackathons")
}

enum HackathonStatus {
  upcoming
  active
  judging
  finished
  cancelled
}

model HackathonRegistration {
  id           String   @id @default(uuid())
  hackathonId  String   @map("hackathon_id")
  userId       String   @map("user_id")
  status       RegistrationStatus @default(registered)
  registeredAt DateTime @default(now()) @map("registered_at")
  checkedInAt  DateTime? @map("checked_in_at")

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, userId])
  @@map("hackathon_registrations")
}

enum RegistrationStatus {
  registered
  cancelled
  checked_in
}

model Team {
  id          String   @id @default(uuid())
  hackathonId String   @map("hackathon_id")
  name        String
  slogan      String?
  captainId   String   @map("captain_id")
  createdAt   DateTime @default(now()) @map("created_at")

  hackathon Hackathon     @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  members   TeamMember[]
  submissions Submission[]

  @@map("teams")
}

model TeamMember {
  id     String   @id @default(uuid())
  teamId String   @map("team_id")
  userId String   @map("user_id")
  role   TeamRole @default(member)

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

enum TeamRole {
  captain
  member
}

model Judge {
  id          String   @id @default(uuid())
  hackathonId String   @map("hackathon_id")
  userId      String?  @map("user_id")
  name        String
  title       String?
  avatarUrl   String?  @map("avatar_url")
  bio         String?  @db.Text

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@map("judges")
}

model Submission {
  id          String   @id @default(uuid())
  hackathonId String   @map("hackathon_id")
  teamId      String?  @map("team_id")
  userId      String?  @map("user_id")
  title       String
  description String   @db.Text
  demoUrl     String?  @map("demo_url")
  repoUrl     String?  @map("repo_url")
  videoUrl    String?  @map("video_url")
  status      SubmissionStatus @default(draft)
  score       Decimal? @db.Decimal(5, 2)
  feedback    String?  @db.Text
  submittedAt DateTime? @map("submitted_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  team      Team?     @relation(fields: [teamId], references: [id], onDelete: SetNull)
  user      User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("submissions")
}

enum SubmissionStatus {
  draft
  submitted
  under_review
  shortlisted
  winner
  rejected
}

model Announcement {
  id          String   @id @default(uuid())
  hackathonId String   @map("hackathon_id")
  title       String
  content     String   @db.Text
  isPinned    Boolean  @default(false) @map("is_pinned")
  createdAt   DateTime @default(now()) @map("created_at")

  hackathon Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)

  @@map("announcements")
}

// ==================== 学习进度 ====================
model ProgressRecord {
  id           String         @id @default(uuid())
  userId       String         @map("user_id")
  courseId     String         @map("course_id")
  lessonId     String         @map("lesson_id")
  status       ProgressStatus @default(not_started)
  completedAt  DateTime?      @map("completed_at")
  lastPosition Int?           @map("last_position")
  updatedAt    DateTime       @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([userId, lessonId])
  @@map("progress_records")
}

enum ProgressStatus {
  not_started
  in_progress
  completed
}

// ==================== 系统日志 ====================
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String
  entityId  String?  @map("entity_id")
  details   String?  @db.Text
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([action, createdAt])
  @@map("audit_logs")
}

// ==================== 实践项目 ====================
model PracticeProject {
  id            String   @id @default(uuid())
  courseId      String   @map("course_id")
  title         String
  description   String   @db.Text
  projectUrl    String   @map("project_url")
  thumbnailUrl  String?  @map("thumbnail_url")
  difficulty    ProjectDifficulty @default(intermediate)
  estimatedTime Int      @default(30) @map("estimated_time") // 分钟
  tags          String?  @db.Text // 逗号分隔
  projectType   ProjectType @map("project_type")
  orderIndex    Int      @default(0) @map("order_index")
  requirements  String?  @db.Text // 前置要求
  objectives    String?  @db.Text // 学习目标
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  completions PracticeCompletion[]

  @@map("practice_projects")
}

enum ProjectDifficulty {
  beginner
  intermediate
  advanced
  expert
}

enum ProjectType {
  model_deployment    // 模型部署
  model_training      // 模型训练
  model_inference     // 模型推理
  api_integration     // API集成
  notebook           // Jupyter Notebook
  sandbox            // 在线沙箱
  repository         // 代码仓库
  csghub_space       // CSGHub Space
}

model PracticeCompletion {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  projectId   String   @map("project_id")
  status      CompletionStatus @default(in_progress)
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  submissionUrl String? @map("submission_url") // 用户提交的链接（可选）
  notes       String?  @db.Text // 学习笔记

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  project PracticeProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("practice_completions")
}

enum CompletionStatus {
  in_progress
  completed
  skipped
}

// ==================== 游戏化：成就徽章 ====================
model Badge {
  id            String           @id @default(uuid())
  code          String           @unique // 程序内唯一标识，如 "first_course"
  name          String
  description   String           @db.Text
  icon          String           @default("award") // lucide 图标名
  category      String           @default("general") // 分组：learning / streak / milestone ...
  criteriaType  BadgeCriteriaType @map("criteria_type")
  criteriaValue Int              @default(1) @map("criteria_value") // 达成阈值
  // P1-3 嵌套规则 DSL(JSON 树,支持 AND/OR/NOT 组合)
  // 为 null 时 fallback 到 criteriaType + criteriaValue
  criteriaJson  Json?            @map("criteria_json")
  points        Int              @default(0) // 解锁奖励积分
  isActive      Boolean          @default(true) @map("is_active")
  orderIndex    Int              @default(0) @map("order_index")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @updatedAt @map("updated_at")

  userBadges UserBadge[]

  @@map("badges")
}

enum BadgeCriteriaType {
  course_completed     // 完成 N 门课程
  lessons_completed    // 累计完成 N 个课时
  streak_days          // 连续学习 N 天
  first_enrollment     // 首次报名（N=1）
  practice_completed   // 完成 N 个实践项目
  points_reached       // 累计积分达到 N
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  badgeId    String   @map("badge_id")
  unlockedAt DateTime @default(now()) @map("unlocked_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@map("user_badges")
}

// ==================== 企业培训咨询 ====================
model EnterpriseInquiry {
  id          String        @id @default(uuid())
  name        String
  email       String
  company     String
  teamSize    String        @map("team_size")
  phone       String?
  topic       String
  description String?       @db.Text
  status      InquiryStatus @default(pending)
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("enterprise_inquiries")
}

enum InquiryStatus {
  pending
  contacted
  qualified
  closed
  archived
}

// ==================== 游戏化：积分流水 ====================
model PointTransaction {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  amount    Int // 正数为获得，负数为扣除
  reason    String // 人类可读原因，如 "完成课时"
  refType   String?  @map("ref_type") // 关联类型：lesson / practice / badge / enrollment
  refId     String?  @map("ref_id")   // 关联实体 ID，用于幂等去重
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, refType, refId]) // 同一来源不重复发放
  @@index([userId, createdAt])
  @@map("point_transactions")
}

// ==================== 课程评价（P1-3）=============
  // 一个 user 对一门课只允许一条评价（@@unique 强制）
// rating: 1-5 整数；helpful: 累计被点赞数（append-only counter）
model Review {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  courseId  String   @map("course_id")
  rating    Int      // 1-5
  content   String   @db.Text
  helpful   Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([courseId, createdAt])
  @@index([courseId, helpful])
  @@map("reviews")
}

// ==================== 通知中心（P1-7）====================
// 站内通知：评论 / 报名 / 黑客松 / 系统 等
// 4 类:type = 'announcement' | 'comment' | 'hackathon' | 'order'
//   - announcement: 系统公告 / 课程更新
//   - comment:      评论 @ 提及 / 讲师回复
//   - hackathon:    黑客松截止提醒 / 评审结果
//   - order:        订单支付成功 / 退款
model Notification {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  type      String    // 4 类之一 (后续如扩展 → enum)
  title     String
  body      String    @db.Text
  linkUrl   String?   @map("link_url")
  isRead    Boolean   @default(false) @map("is_read")
  readAt    DateTime? @map("read_at")
  deletedAt DateTime? @map("deleted_at") // 软删
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([userId, deletedAt, createdAt])
  @@map("notifications")
}

// ==================== P2: AI 助教 / 学情事件 ====================
// 详见 review/redesign-spec.md §6.1

model ChatSession {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  // scope 用 'lesson:<id>' | 'general' 形式,P2 先做 lesson
  lessonId  String?  @map("lesson_id")
  title     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson   Lesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  messages ChatMessage[]

  @@index([userId, lessonId])
  @@index([userId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id        String   @id @default(uuid())
  sessionId String   @map("session_id")
  // 'user' | 'assistant' | 'system'
  role      String
  content   String   @db.Text
  // mock 阶段每条 100 tokens,P2 切真 AI 时改用 tokensIn / tokensOut
  tokens    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}

model LearningEvent {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  lessonId    String?  @map("lesson_id")
  // 'play' | 'pause' | 'seek' | 'complete' | 'replay' | 'skip' | 'note'
  eventType   String   @map("event_type")
  positionSec Int?     @map("position_sec")
  durationMs  Int?     @map("duration_ms")
  metadata    Json?
  createdAt   DateTime @default(now()) @map("created_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  lesson Lesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([lessonId, eventType])
  @@map("learning_events")
}

// AI token 用量（P2 看板 + cost 监控用）
// 每调一次 AI 写一条,mock 阶段 tokensIn/Out 都填 0 或 100
model AiUsage {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  // 'chat' | 'content_gen' | 'recommend' | ...
  feature   String
  tokensIn  Int      @default(0) @map("tokens_in")
  tokensOut Int      @default(0) @map("tokens_out")
  // 估算成本(USD);mock 阶段填 0
  cost      Decimal  @default(0) @db.Decimal(10, 4)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@map("ai_usage")
}

// 注: Review model 已在 P1-3 评价系统 (line 700 附近) 完整定义, 这里不重复.
// 之前 dev DB 的 reviews 表跟 schema 重复, 但 prisma migrate deploy 会处理 (用 P1-3 那一份).

// ==================== P1-3 评价: 完整 Review model 已合并, 这里是 P2 chat/learning event 附加 ====================

// ==================== CMS 基础设施 (2026-07-21) ====================
// 把所有 UI 硬编码 (文案 / 列表 / enum label / 业务规则) 迁到后台可配置
// 见 review/cms-design.md §1 schema 约定

// §1.1 核心 3 张表

// 全局 key-value 配置 (duration_buckets / number_format / ai.quick_prompts 等)
model AppSetting {
  key         String   @id
  valueJson   Json     @map("value_json")
  scope       String   @default("global")
  description String?  @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("app_settings")
}

// 枚举 i18n (label + color + icon), 组合主键 (enumType, enumValue, locale)
model EnumTranslation {
  enumType   String  @map("enum_type")
  enumValue  String  @map("enum_value")
  locale     String  @default("zh-CN")
  label      String
  colorClass String? @map("color_class")
  icon       String?
  sortOrder  Int     @default(0) @map("sort_order")

  @@id([enumType, enumValue, locale])
  @@index([enumType, locale])
  @@map("enum_translations")
}

// 日期/时间格式模板
model DateFormatTemplate {
  scope    String
  locale   String  @default("zh-CN")
  template String

  @@id([scope, locale])
  @@map("date_format_templates")
}

// §1.2 品牌文案 2 张

// 全局品牌文案 (hero / footer / auth shell / nav)
model SiteSetting {
  key         String   @id
  value       Json
  scope       String   @default("global")
  description String?  @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("site_settings")
}

// 页面级文案 (按路由)
model PageSetting {
  page        String
  key         String
  value       Json
  description String?  @db.Text
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@id([page, key])
  @@index([page])
  @@map("page_settings")
}

// §1.3 结构化列表 10 张

// 行业 (金融 / 电商 / ...)
model Industry {
  id          String   @id @default(cuid())
  key         String   @unique
  label       String
  description String?  @db.Text
  icon        String?
  methodology Json?
  isActive    Boolean  @default(true) @map("is_active")
  orderIndex  Int      @default(0) @map("order_index")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("industries")
}

// 企业方法论 (3 步法)
model EnterpriseMethod {
  id         String  @id @default(cuid())
  num        String
  title      String
  desc       String  @db.Text
  bullets    Json
  isActive   Boolean @default(true) @map("is_active")
  orderIndex Int     @default(0) @map("order_index")

  @@map("enterprise_methods")
}

// 学员故事 / 证言
model Testimonial {
  id         String  @id @default(cuid())
  name       String
  title      String
  quote      String  @db.Text
  avatar     String?
  isActive   Boolean @default(true) @map("is_active")
  orderIndex Int     @default(0) @map("order_index")

  @@map("testimonials")
}

// AI 快捷 prompt (dashboard 助手 / lesson 内)
model QuickPrompt {
  id         String  @id @default(cuid())
  emoji      String  @default("💡")
  label      String
  promptText String  @map("prompt_text") @db.Text
  scope      String  @default("lesson")
  isActive   Boolean @default(true) @map("is_active")
  orderIndex Int     @default(0) @map("order_index")

  @@map("quick_prompts")
}

// 课程分类 (LLM 应用 / RAG / Agent / ...)
model CourseCategory {
  id         String  @id @default(cuid())
  key        String  @unique
  label      String
  isActive   Boolean @default(true) @map("is_active")
  orderIndex Int     @default(0) @map("order_index")

  @@map("course_categories")
}

// 热门搜索词 (含点击数)
model PopularSearch {
  id         String  @id @default(cuid())
  keyword    String  @unique
  clickCount Int     @default(0) @map("click_count")
  isActive   Boolean @default(true) @map("is_active")
  orderIndex Int     @default(0) @map("order_index")

  @@map("popular_searches")
}

// 热词 (按 scope: courses / home / search)
model HotKeyword {
  id         String  @id @default(cuid())
  keyword    String
  scope      String  @default("courses")
  isActive   Boolean @default(true) @map("is_active")
  orderIndex Int     @default(0) @map("order_index")

  @@map("hot_keywords")
}

// 第三方登录 provider (Google / GitHub / 微信 / ...)
model AuthProvider {
  id         String  @id
  label      String
  icon       String
  isActive   Boolean @default(false) @map("is_active")
  orderIndex Int     @default(0) @map("order_index")
  config     Json?

  @@map("auth_providers")
}

// 顶部导航项
model TopNavItem {
  id         String  @id @default(cuid())
  label      String
  path       String
  icon       String?
  isActive   Boolean @default(true) @map("is_active")
  orderIndex Int     @default(0) @map("order_index")

  @@map("top_nav_items")
}

// Footer 列
model FooterColumn {
  id         String  @id @default(cuid())
  title      String
  links      Json
  isActive   Boolean @default(true) @map("is_active")
  orderIndex Int     @default(0) @map("order_index")

  @@map("footer_columns")
}

// §1.4 i18n 1 张

// 通用文案 (key 模式, 按 locale)
model I18nMessage {
  key      String @db.VarChar(255)
  locale   String @default("zh-CN")
  value    String @db.Text
  category String @default("common")

  @@id([key, locale])
  @@index([category])
  @@map("i18n_messages")
}
