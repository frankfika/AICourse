// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     Course[]
}

model Instructor {
  id          String   @id @default(uuid())
  name        String
  email       String   @unique
  avatar      String
  title       String
  bio         String
  experience  String?
  socialLinks String?  // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  courses     Course[]
}

model Course {
  id                 String   @id @default(uuid())
  title              String
  slug               String   @unique
  shortDescription   String
  description        String
  coverImage         String
  previewVideoUrl    String?
  duration           Int      // minutes
  level              String   // beginner, intermediate, advanced
  categoryId         String
  instructorId       String
  prerequisites      String   // JSON array
  learningObjectives String   // JSON array
  highlights         String   // JSON array
  targetAudience     String
  suggestedWeeks     Int?
  hoursPerWeek       Int?
  viewCount          Int      @default(0)
  enrollCount        Int      @default(0)
  featured           Boolean  @default(false)
  status             String   @default("draft") // draft, published, archived

  // Pricing
  price              Float    @default(0) // 0 means free
  originalPrice      Float?   // Original price for discount display
  currency           String   @default("CNY")

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  category           Category    @relation(fields: [categoryId], references: [id])
  instructor         Instructor  @relation(fields: [instructorId], references: [id])
  chapters           Chapter[]
  faqs               CourseFAQ[]
  nanoDegreeCourses  NanoDegreeCourse[]
  enrollments        Enrollment[]
}

model Chapter {
  id        String   @id @default(uuid())
  courseId  String
  title     String
  duration  Int      // minutes
  topics    String   // JSON array
  videoUrl  String?  // 视频链接（支持YouTube, Bilibili等）
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress  ChapterProgress[]
}

model CourseFAQ {
  id        String   @id @default(uuid())
  courseId  String
  question  String
  answer    String
  order     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  course    Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)
}

model NanoDegree {
  id                     String   @id @default(uuid())
  title                  String
  slug                   String   @unique
  shortDescription       String
  description            String
  coverImage             String
  previewVideoUrl        String?
  level                  String   // beginner, intermediate, advanced
  certificateImage       String
  certificateDescription String
  certificateType        String
  completionCriteria     String
  learningPath           String
  skills                 String   // JSON array
  highlights             String   // JSON array
  targetAudience         String
  prerequisites          String   // JSON array
  suggestedMonths        Int?
  hoursPerWeek           Int?
  viewCount              Int      @default(0)
  enrollCount            Int      @default(0)
  featured               Boolean  @default(false)
  status                 String   @default("draft") // draft, published, archived

  // Pricing
  price                  Float    @default(0) // 0 means free
  originalPrice          Float?   // Original price for discount display
  currency               String   @default("CNY")

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  courses                NanoDegreeCourse[]
  faqs                   NanoDegreeFAQ[]
  enrollments            NanoDegreeEnrollment[]
}

model NanoDegreeCourse {
  id            String   @id @default(uuid())
  nanoDegreeId  String
  courseId      String
  order         Int
  createdAt     DateTime @default(now())

  nanoDegree    NanoDegree @relation(fields: [nanoDegreeId], references: [id], onDelete: Cascade)
  course        Course     @relation(fields: [courseId], references: [id])

  @@unique([nanoDegreeId, courseId])
}

model NanoDegreeFAQ {
  id            String   @id @default(uuid())
  nanoDegreeId  String
  question      String
  answer        String
  order         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  nanoDegree    NanoDegree @relation(fields: [nanoDegreeId], references: [id], onDelete: Cascade)
}

model Banner {
  id            String   @id @default(uuid())
  title         String
  image         String
  link          String?
  openInNewTab  Boolean  @default(false)
  isActive      Boolean  @default(true)
  order         Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SiteConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // JSON string
  updatedAt DateTime @updatedAt
}

model Admin {
  id           String   @id @default(uuid())
  username     String   @unique
  email        String   @unique
  passwordHash String
  name         String
  role         String   @default("admin") // admin, super_admin
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// 前台用户模型
model User {
  id                    String                 @id @default(uuid())
  email                 String                 @unique
  passwordHash          String
  name                  String
  avatar                String?                @default("https://api.dicebear.com/7.x/avataaars/svg?seed=default")
  bio                   String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  enrollments           Enrollment[]
  nanoDegreeEnrollments NanoDegreeEnrollment[]
  chapterProgress       ChapterProgress[]
  orders                Order[]
  certificates          Certificate[]
}

// 课程注册（已购买或免费获取）
model Enrollment {
  id               String   @id @default(uuid())
  userId           String
  courseId         String
  enrolledAt       DateTime @default(now())
  lastAccessedAt   DateTime @default(now())
  completedAt      DateTime?
  progress         Int      @default(0) // 0-100

  // 购买信息
  orderId          String?  // 关联订单ID（免费课程为null）
  accessExpiresAt  DateTime? // 访问过期时间（终身访问为null）

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  course           Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@index([orderId])
}

// 认证项目注册
model NanoDegreeEnrollment {
  id               String     @id @default(uuid())
  userId           String
  nanoDegreeId     String
  enrolledAt       DateTime   @default(now())
  lastAccessedAt   DateTime   @default(now())
  completedAt      DateTime?
  progress         Int        @default(0) // 0-100

  // 购买信息
  orderId          String?
  accessExpiresAt  DateTime?

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  nanoDegree       NanoDegree @relation(fields: [nanoDegreeId], references: [id], onDelete: Cascade)

  @@unique([userId, nanoDegreeId])
  @@index([userId])
  @@index([nanoDegreeId])
  @@index([orderId])
}

// 章节学习进度
model ChapterProgress {
  id               String   @id @default(uuid())
  userId           String
  chapterId        String
  completed        Boolean  @default(false)
  completedAt      DateTime?
  lastPosition     Int      @default(0) // 视频播放位置（秒）
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapter          Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)

  @@unique([userId, chapterId])
  @@index([userId])
  @@index([chapterId])
}

// 订单系统
model Order {
  id               String    @id @default(uuid())
  orderNo          String    @unique // 订单号
  userId           String

  // 商品信息（冗余存储，避免外键依赖）
  itemType         String    // course, nanodegree
  itemId           String    // courseId or nanoDegreeId
  itemTitle        String    // 商品标题
  itemCoverImage   String?   // 商品封面

  // 价格信息
  amount           Float     // 实付金额
  originalAmount   Float     // 原价
  currency         String    @default("CNY")

  // 支付信息
  paymentMethod    String?   // alipay, wechat, stripe, mock
  paymentId        String?   // 第三方支付ID
  paidAt           DateTime?

  // 状态
  status           String    @default("pending") // pending, paid, cancelled, refunded

  // 退款信息
  refundedAt       DateTime?
  refundReason     String?
  refundAmount     Float?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([orderNo])
  @@index([status])
  @@index([itemType, itemId])
}

// 证书系统
model Certificate {
  id               String    @id @default(uuid())
  certificateNo    String    @unique // 证书编号
  userId           String

  // 证书信息
  type             String    // course, nanodegree
  itemId           String    // courseId or nanoDegreeId
  itemTitle        String    // 课程/认证项目标题

  // 完成信息
  completedAt      DateTime
  score            Float?    // 成绩（可选）

  // 证书文件
  certificateUrl   String?   // PDF/图片URL
  certificateData  String?   // JSON格式的证书数据（用于生成）

  // 状态
  status           String    @default("active") // active, revoked
  revokedAt        DateTime?
  revokeReason     String?

  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([certificateNo])
  @@index([type, itemId])
  @@index([status])
}

