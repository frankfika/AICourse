# ============================================
# OpenCSG Academy - 本地开发环境变量模板
# 复制为 .env 后填入真实值
# ============================================

# ------------------- 基础设施 -------------------
MYSQL_ROOT_PASSWORD=opencsg_root
MYSQL_DATABASE=opencsg_academy
MYSQL_USER=opencsg
MYSQL_PASSWORD=opencsg_pass
MYSQL_PORT=3307

REDIS_PORT=6380

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_PORT=9010
MINIO_CONSOLE_PORT=9011
MINIO_BUCKET=opencsg-academy
MINIO_ENDPOINT=localhost
MINIO_USE_SSL=false

# ------------------- 数据库连接 -------------------
DATABASE_URL="mysql://opencsg:opencsg_pass@localhost:3307/opencsg_academy"

# ------------------- JWT 认证 -------------------
# 必填：32 字符以上强随机字符串
# 生成方法：openssl rand -hex 32
# 启动时若 secret 缺失 / 过短 / 含 placeholder 字样，API 拒绝启动
JWT_SECRET=""
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# ------------------- Auth Provider 配置 -------------------
# 可插拔 + 配置驱动（详见 apps/api/src/modules/auth/config/auth.config.ts）
# 逗号分隔要启用的 provider id,留空则只走 email_password
# AUTH_PROVIDERS="email_password,oauth.google,oauth.github,sso.saml"

# EmailPassword（永远可用,无需额外 env;bcrypt cost 可调）
# AUTH_BCRYPT_ROUNDS=12

# OAuth - Google（启用 oauth.google 时必填）
# AUTH_OAUTH_GOOGLE_CLIENT_ID=""
# AUTH_OAUTH_GOOGLE_CLIENT_SECRET=""
# AUTH_OAUTH_GOOGLE_REDIRECT_URI="http://localhost:3000/auth/google/callback"

# OAuth - GitHub（启用 oauth.github 时必填）
# AUTH_OAUTH_GITHUB_CLIENT_ID=""
# AUTH_OAUTH_GITHUB_CLIENT_SECRET=""
# AUTH_OAUTH_GITHUB_REDIRECT_URI="http://localhost:3000/auth/github/callback"

# SSO - SAML 2.0（启用 sso.saml 时必填,实现待下一刀）
# AUTH_SSO_SAML_ENTRY_POINT="https://idp.example.com/sso"
# AUTH_SSO_SAML_ISSUER="opencsg-academy"
# AUTH_SSO_SAML_CALLBACK_URL="http://localhost:8080/api/v1/auth/sso/saml/callback"
# AUTH_SSO_SAML_CERT=""

# ------------------- Stripe 支付（可选）-------------------
# ⚠️ 当前使用 mockPay，生产接入时取消注释以下行
# STRIPE_SECRET_KEY="sk_live_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."
# STRIPE_SUCCESS_URL="http://localhost:3000/payment/success"
# STRIPE_CANCEL_URL="http://localhost:3000/payment/cancel"

# ------------------- 对象存储（生产） -------------------
# AWS S3 / 阿里云 OSS 配置（可选，开发时可用 MinIO）
# S3_ENDPOINT=""
# S3_REGION=""
# S3_ACCESS_KEY_ID=""
# S3_SECRET_ACCESS_KEY=""
# S3_BUCKET=""

# ------------------- AI 服务（Gemini） -------------------
# 获取方式：https://makersuite.google.com/app/apikey
# 不填则使用规则化兜底生成（仍然可用，但不调用 LLM）
GEMINI_API_KEY=""
# 模型选项（默认 gemini-2.0-flash）
GEMINI_MODEL="gemini-2.0-flash"

# ------------------- 加密 master key (P0 修复 2026-07-24) -------------------
# 用于加密 admin 后台保存的 AI API key (AES-256-GCM).
# 生成方法: openssl rand -hex 32
# 不填则在 admin 保存 AI key 时报错 (fail-closed).
AI_KEY_ENCRYPTION_KEY=""

# ------------------- Email 通知（可选） -------------------
# 不填则打印到 console.log，生产建议接入 SendGrid / AWS SES / 钉钉机器人
# EMAIL_PROVIDER="console"   # console | sendgrid | ses
# SENDGRID_API_KEY=""
# EMAIL_FROM="noreply@opencsg.com"

# ------------------- 前端配置 -------------------
VITE_API_BASE_URL="http://localhost:8080"
VITE_STRIPE_PUBLIC_KEY="pk_test_..."

# ------------------- 后端配置 -------------------
API_PORT=8080
API_HOST=0.0.0.0
# 多个 origin 用逗号分隔（前端改了端口时在这里加新 origin，重启 API 生效）
CORS_ORIGIN="http://localhost:3000,http://localhost:5500"
NODE_ENV=development
